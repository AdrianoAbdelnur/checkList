{
  "id": "cargo_transport_checklist",
  "templateId": "cargo_transport_checklist",
  "version": 1,
  "title": "Checklist Transporte de Carga",
  "shortTitle": "Transp. de carga",
  "sections": [
    {
      "id": "main",
      "title": "Datos iniciales",
      "description": "Datos generales del control y de la unidad",
      "isMain": true,
      "fields": [
        {
          "id": "vehicle_domain",
          "kind": "text",
          "label": "Patente",
          "required": true,
          "uppercase": true,
          "placeholder": "AA123BB",
          "showCamera": true
        },
        {
          "id": "trip_date",
          "kind": "date",
          "label": "Fecha de viaje",
          "required": true,
          "defaultToday": true,
          "editable": true,
          "futureOnly": true
        },
        {
          "id": "check_date",
          "kind": "date",
          "label": "Fecha",
          "required": true,
          "editable": false,
          "defaultToday": true
        },
        {
          "id": "check_place",
          "kind": "text",
          "label": "Lugar",
          "required": false,
          "multiline": false,
          "placeholder": "Escribi aqui..."
        }
      ]
    },
    {
      "id": "driver_vehicle_docs",
      "title": "Documentación del chofer y vehículo",
      "description": "¡Asegúrese de llevar la documentación obligatoria según la carga, y planifique la ruta antes de emprender el viaje!",
      "fields": [
        {
          "id": "pre_name",
          "kind": "text",
          "label": "Nombre y Apellido",
          "required": false,
          "placeholder": "Escribi aqui..."
        },
        {
          "id": "pre_company",
          "kind": "text",
          "label": "Empresa",
          "required": false,
          "placeholder": "Escribi aqui..."
        },
        {
          "id": "pre_lnc_lnh",
          "kind": "text",
          "label": "LNC-LNH",
          "required": false,
          "uppercase": true,
          "placeholder": "Escribi aqui..."
        },
        {
          "id": "pre_tractor_year",
          "kind": "number",
          "label": "Tractor / Chasis: Año de Fabricación",
          "required": false,
          "min": 1900,
          "max": 2100
        },
        {
          "id": "pre_trailer_year",
          "kind": "number",
          "label": "Remolque: Año de Fabricación",
          "required": false,
          "min": 1900,
          "max": 2100
        },
        {
          "id": "pre_trailer_domain",
          "kind": "text",
          "label": "Remolque: Dominio",
          "required": false,
          "uppercase": true,
          "placeholder": "AA123BB"
        },
        {
          "id": "pre_tractor_green_card",
          "kind": "yesNo",
          "label": "Tractor / Chasis: Posee cédula verde",
          "required": false
        },
        {
          "id": "pre_trailer_green_card",
          "kind": "yesNo",
          "label": "Remolque: Posee cédula verde",
          "required": false
        },
        {
          "id": "pre_tractor_insurance_exp",
          "kind": "date",
          "label": "Tractor / Chasis: Vencimiento de Seguro",
          "required": false,
          "editable": true,
          "defaultToday": false
        },
        {
          "id": "pre_trailer_insurance_exp",
          "kind": "date",
          "label": "Remolque: Vencimiento de Seguro",
          "required": false,
          "editable": true,
          "defaultToday": false
        },
        {
          "id": "pre_tractor_rto_exp",
          "kind": "date",
          "label": "Tractor / Chasis: Vencimiento de RTO",
          "required": false,
          "editable": true,
          "defaultToday": false
        },
        {
          "id": "pre_trailer_rto_exp",
          "kind": "date",
          "label": "Remolque: Vencimiento de RTO",
          "required": false,
          "editable": true,
          "defaultToday": false
        }
      ]
    },
    {
      "id": "cargo_docs",
      "title": "Documentación de la carga transportada",
      "fields": [
        {
          "id": "cargo_invoice_waybill",
          "kind": "yesNo",
          "label": "Remito / Factura / Carta de porte",
          "required": false
        },
        {
          "id": "cargo_route_sheet",
          "kind": "yesNo",
          "label": "Hoja de ruta / Plan de viaje",
          "required": false
        },
        {
          "id": "cargo_contingency_plan",
          "kind": "yesNo",
          "label": "Plan de contingencia",
          "required": false
        },
        {
          "id": "cargo_specific_docs",
          "kind": "yesNo",
          "label": "Documentación específica para el tipo de carga",
          "required": false
        }
      ]
    },
    {
      "id": "communication",
      "title": "Comunicación",
      "description": "Sistema de Comunicación Bidireccional – de datos continuo en tiempo real",
      "fields": [
        {
          "id": "comm_satellite",
          "kind": "yesNo",
          "label": "Comunicación Satelital",
          "required": false,
