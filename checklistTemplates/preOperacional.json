  "sections": [
    {
      "id": "main",
      "title": "Datos iniciales",
      "isMain": true,
      "fields": [
        {
          "id": "vehicle_domain",
          "kind": "text",
          "label": "Patente",
          "required": true,
          "uppercase": true,
          "placeholder": "AA123BB",
          "showCamera": true
        },
        {
          "id": "trip_date",
          "kind": "date",
          "label": "Fecha de viaje",
          "required": true,
          "defaultToday": true,
          "editable": true,
          "futureOnly": true
        },
        {
          "id": "driver_name",
          "kind": "text",
          "label": "Nombre del conductor",
          "required": false,
          "placeholder": "Escribi aqui..."
        },
        {
          "id": "driver_dni",
          "kind": "number",
          "label": "DNI",
          "required": false
        },
        {
          "id": "driver_signature",
          "kind": "signature",
          "label": "Firma",
          "required": false
        },
        {
          "id": "check_date",
          "kind": "date",
          "label": "Fecha",
          "required": true,
          "editable": false,
          "defaultToday": true
        },
        {
          "id": "company",
          "kind": "text",
          "label": "Empresa",
          "required": false,
          "placeholder": "Escribi aqui..."
        },
        {
          "id": "vehicle_km",
          "kind": "number",
          "label": "Kilómetros",
          "required": false
        },
        {
          "id": "project_area",
          "kind": "text",
          "label": "Proyecto/Área",
          "required": false,
          "placeholder": "Escribi aqui..."
        },
        {
          "id": "fuel_level",
          "kind": "radioGroup",
          "label": "Nivel de combustible",
          "required": false,
          "options": [
            {
              "value": "E",
              "label": "E"
            },
            {
              "value": "Q1",
              "label": "1/4"
            },
            {
              "value": "Q2",
              "label": "1/2"
            },
            {
              "value": "Q3",
              "label": "3/4"
            },
            {
              "value": "F",
              "label": "F"
            }
          ]
        },
        {
          "id": "operability_result",
          "kind": "radioGroup",
          "label": "Condición operativa del vehículo",
          "required": false,
          "options": [
            {
              "value": "NO_OPERAR",
              "label": "El vehículo no debe ser operado"
            },
            {
              "value": "SUPERVISOR",
              "label": "No será operado hasta autorización del supervisor"
            },
            {
              "value": "OPERAR",
              "label": "El vehículo puede ser operado"
            }
          ]
